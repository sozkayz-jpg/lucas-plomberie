---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { COMPANY } from "../data/company";
---

<BaseLayout
  title="Contact & Devis gratuit"
  description="Contactez Lucas Plomberie à Lyon pour un devis gratuit. Intervention rapide 24h/24. Appelez-nous au 04 27 00 00 00."
>
  <Header />

  <main class="pt-16">
    <!-- Hero -->
    <section class="relative py-20 md:py-28 bg-ink overflow-hidden">
      <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1920&q=80&fit=crop" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20"/>
      <div class="absolute inset-0 bg-gradient-to-b from-ink/90 via-ink/80 to-ink/90"></div>
      <div class="container-site relative z-10">
        <div class="max-w-3xl">
          <span class="inline-block text-copper font-bold uppercase tracking-[0.25em] text-xs bg-copper/10 px-4 py-2 rounded-full mb-6 border border-copper/20">Contact</span>
          <h1 class="text-display text-white mb-6">Parlons de<br/><span class="text-copper">votre projet</span></h1>
          <p class="text-zinc-400 text-xl leading-relaxed max-w-lg">Urgence, devis ou simple conseil : nous sommes à votre écoute 24h/24.</p>
        </div>
      </div>
    </section>

    <!-- Contact content -->
    <section class="py-24 md:py-28 bg-canvas">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-14 lg:gap-16">
          <!-- Form -->
          <div class="lg:col-span-3">
            <h2 class="text-heading text-ink mb-2">Demandez votre <span class="text-copper">devis gratuit</span></h2>
            <p class="text-steel mb-8">Réponse sous 2h en journée, sous 30 min pour les urgences.</p>

            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-semibold text-ink mb-2">Nom complet *</label>
                  <input type="text" id="name" name="name" required placeholder="Votre nom" class="w-full px-4 py-3.5 rounded-xl bg-surface border border-hairline text-ink placeholder:text-steel-light focus:outline-none focus:border-copper focus:ring-4 focus:ring-copper/10 transition-all duration-300"/>
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-ink mb-2">Téléphone *</label>
                  <input type="tel" id="phone" name="phone" required placeholder="06 00 00 00 00" class="w-full px-4 py-3.5 rounded-xl bg-surface border border-hairline text-ink placeholder:text-steel-light focus:outline-none focus:border-copper focus:ring-4 focus:ring-copper/10 transition-all duration-300"/>
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-ink mb-2">Email *</label>
                <input type="email" id="email" name="email" required placeholder="votre@email.fr" class="w-full px-4 py-3.5 rounded-xl bg-surface border border-hairline text-ink placeholder:text-steel-light focus:outline-none focus:border-copper focus:ring-4 focus:ring-copper/10 transition-all duration-300"/>
              </div>
              <div>
                <label for="service" class="block text-sm font-semibold text-ink mb-2">Type de service</label>
                <select id="service" name="service" class="w-full px-4 py-3.5 rounded-xl bg-surface border border-hairline text-ink focus:outline-none focus:border-copper focus:ring-4 focus:ring-copper/10 transition-all duration-300">
                  <option value="">Sélectionnez un service</option>
                  <option value="debouchage">Débouchage & nettoyage</option>
                  <option value="fuite">Recherche & réparation de fuites</option>
                  <option value="installation">Installation sanitaire</option>
                  <option value="chauffe-eau">Chauffe-eau & ballon</option>
                  <option value="detartrage">Détartrage & entretien</option>
                  <option value="renovation">Rénovation salle de bain</option>
                  <option value="autre">Autre</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-ink mb-2">Votre message *</label>
                <textarea id="message" name="message" required rows={4} placeholder="Décrivez votre besoin..." class="w-full px-4 py-3.5 rounded-xl bg-surface border border-hairline text-ink placeholder:text-steel-light focus:outline-none focus:border-copper focus:ring-4 focus:ring-copper/10 transition-all duration-300 resize-none"></textarea>
              </div>
              <div class="flex items-start gap-3">
                <input type="checkbox" id="consent" name="consent" required class="mt-1 w-4 h-4 rounded accent-copper"/>
                <label for="consent" class="text-steel text-sm leading-relaxed">J'accepte que mes données soient collectées conformément à la <a href="/politique-confidentialite" class="text-copper hover:text-copper-deep underline font-medium">politique de confidentialité</a>.</label>
              </div>
              <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-copper hover:bg-copper-bright text-white px-8 py-4 rounded-btn font-bold text-base transition-all duration-300 shadow-xl shadow-copper/20 hover:shadow-copper/30">
                Envoyer ma demande
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              <div id="form-success" class="hidden bg-emerald-50 text-emerald-700 border border-emerald-200 px-6 py-4 rounded-xl text-sm font-semibold">Merci ! Nous vous recontactons très rapidement.</div>
            </form>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-2 space-y-6">
            <div class="bg-surface rounded-2xl p-7 border border-hairline">
              <h3 class="text-lg font-bold text-ink mb-5">Coordonnées</h3>
              <div class="space-y-4">
                <a href="tel:0427000000" class="flex items-center gap-3 text-ink hover:text-copper transition-colors group">
                  <div class="w-10 h-10 rounded-full bg-copper/10 text-copper flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                  <span class="font-bold text-lg">{COMPANY.phoneDisplay}</span>
                </a>
                <a href={`mailto:${COMPANY.email}`} class="flex items-center gap-3 text-ink hover:text-copper transition-colors">
                  <div class="w-10 h-10 rounded-full bg-copper/10 text-copper flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
                  <span>{COMPANY.email}</span>
                </a>
                {COMPANY.addresses.map(addr => (
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-full bg-copper/10 text-copper flex items-center justify-center shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
                    <div><p class="text-ink font-medium">{addr.street}</p><p class="text-steel text-sm">{addr.zip} {addr.city}</p></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="bg-copper rounded-2xl p-7 text-white relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-white/10 blur-2xl" aria-hidden="true"></div>
              <div class="relative z-10">
                <div class="flex items-center gap-2 mb-3"><span class="relative flex h-2.5 w-2.5"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span><span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-white"></span></span><span class="text-white/80 font-semibold text-xs uppercase tracking-wider">Urgence 24/7</span></div>
                <p class="text-2xl font-extrabold mb-2">Intervention en {COMPANY.delay}</p>
                <p class="text-copper-light text-sm leading-relaxed mb-4">Appelez directement, un technicien se tient prêt à intervenir.</p>
                <a href="tel:0427000000" class="inline-flex items-center gap-2 bg-white text-copper px-6 py-3 rounded-btn font-bold text-sm hover:bg-ink hover:text-white transition-all duration-300">{COMPANY.phoneDisplay}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <CookieBanner />
</BaseLayout>

<script>
  const form = document.getElementById("contact-form");
  const success = document.getElementById("form-success");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    try { await fetch("/", { method: "POST", body: new URLSearchParams(formData as any).toString() }); } catch {}
    form.reset();
    success?.classList.remove("hidden");
    setTimeout(() => success?.classList.add("hidden"), 5000);
  });
</script>
