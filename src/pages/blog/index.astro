---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CTABanner from "../../components/CTABanner.astro";
import CookieBanner from "../../components/CookieBanner.astro";
import { BLOG_ARTICLES } from "../../data/company";

const bgColors = ["from-copper/30 to-copper/5", "from-steel/30 to-steel/5", "from-copper/20 to-copper/3"];
---

<BaseLayout title="Blog" description="Le blog de Lucas Plomberie — Conseils, astuces et actualités sur la plomberie à Lyon.">
  <Header />

  <main class="pt-16">
    <section class="relative py-20 md:py-28 bg-ink overflow-hidden">
      <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1920&q=80&fit=crop" alt="" class="absolute inset-0 w-full h-full object-cover opacity-15"/>
      <div class="absolute inset-0 bg-gradient-to-b from-ink/95 to-ink/80"></div>
      <div class="container-site relative z-10">
        <span class="inline-block text-copper font-bold uppercase tracking-[0.25em] text-xs bg-copper/10 px-4 py-2 rounded-full mb-6 border border-copper/20">Blog</span>
        <h1 class="text-display text-white mb-6">Conseils &<br/><span class="text-copper">actualités</span></h1>
        <p class="text-zinc-400 text-xl max-w-lg">Tout ce que vous devez savoir pour prendre soin de vos installations.</p>
      </div>
    </section>

    <section class="py-24 md:py-28 bg-canvas">
      <div class="container-site">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {BLOG_ARTICLES.map((article, idx) => (
            <a href={`/blog/${article.slug}`} class="group block bg-surface rounded-2xl overflow-hidden border border-hairline hover:border-copper/30 hover:shadow-xl transition-all duration-500">
              <div class={`relative h-52 bg-gradient-to-br ${bgColors[idx]} flex items-center justify-center`}>
                <span class="absolute top-4 left-4 bg-white/90 text-ink text-xs font-bold px-3 py-1.5 rounded-full z-10">Conseil</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" class="text-copper/25 group-hover:scale-110 transition-transform duration-700" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <div class="p-6">
                <time datetime={article.date} class="text-steel text-xs mb-3 block">{new Date(article.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</time>
                <h2 class="text-lg font-bold text-ink group-hover:text-copper transition-colors leading-snug mb-3">{article.title}</h2>
                <p class="text-steel text-sm leading-relaxed line-clamp-2">{article.excerpt}</p>
                <span class="inline-flex items-center gap-1.5 text-copper font-bold text-sm mt-4 group-hover:gap-2.5 transition-all">Lire l'article <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <CTABanner />
  <Footer />
  <CookieBanner />
</BaseLayout>
