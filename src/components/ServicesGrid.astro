---
import { SERVICES } from "../data/company";

const images = [
  "https://images.unsplash.com/photo-1542013936693-884638332954?w=800&q=80&fit=crop",
  "https://images.unsplash.com/photo-1521207418485-99c9086e4f58?w=800&q=80&fit=crop",
  "https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80&fit=crop",
  "https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=800&q=80&fit=crop",
  "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=800&q=80&fit=crop",
  "https://images.unsplash.com/photo-1602872030219-ad2b0d3f8f48?w=800&q=80&fit=crop",
];
---

<section class="relative py-24 md:py-28 bg-canvas overflow-hidden">
  <div class="container-site relative z-10">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <span class="inline-block text-copper font-bold uppercase tracking-[0.25em] text-xs bg-copper/5 px-4 py-2 rounded-full mb-6">
        Nos expertises
      </span>
      <h2 class="text-display text-ink mb-5">
        Des solutions<br class="md:hidden" />
        <span class="text-copper">sur mesure</span>
      </h2>
      <p class="text-steel-dark text-body-lg max-w-lg mx-auto">
        Six domaines d'excellence pour couvrir l'ensemble de vos besoins en plomberie, du dépannage à la rénovation complète.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {SERVICES.map((service, idx) => (
        <a
          href={`/services/${service.slug}`}
          class="group relative flex flex-col rounded-[1.75rem] overflow-hidden bg-surface border border-hairline hover:border-copper/30 hover:shadow-2xl transition-all duration-700"
        >
          <!-- Card image -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={images[idx]}
              alt=""
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/20 to-transparent"></div>
            <!-- Number badge -->
            <div class="absolute top-4 right-4 w-10 h-10 rounded-xl bg-white/90 backdrop-blur-sm text-ink font-extrabold text-sm flex items-center justify-center shadow-lg">
              {(idx + 1).toString().padStart(2, "0")}
            </div>
          </div>
          <!-- Card content -->
          <div class="p-6 pb-7 flex-1 flex flex-col">
            <h3 class="text-xl font-bold text-ink mb-2.5 group-hover:text-copper transition-colors duration-300">
              {service.title}
            </h3>
            <p class="text-steel text-sm leading-relaxed flex-1">
              {service.description}
            </p>
            <div class="flex items-center gap-2 text-copper font-bold text-sm mt-5 group-hover:gap-3 transition-all duration-300">
              Découvrir
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
