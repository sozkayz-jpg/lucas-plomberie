---
import { BLOG_ARTICLES } from "../data/company";

const bgColors = ["from-copper/30 to-copper/5", "from-steel/30 to-steel/5", "from-copper/20 to-copper/3"];
---

<section class="py-24 md:py-28 bg-surface">
  <div class="container-site">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-4">
      <div>
        <span class="inline-block text-copper font-bold uppercase tracking-[0.25em] text-xs bg-copper/5 px-4 py-2 rounded-full mb-5">
          Blog
        </span>
        <h2 class="text-display text-ink">
          Conseils<br class="md:hidden" />
          <span class="text-copper">& astuces</span>
        </h2>
      </div>
      <a href="/blog" class="group inline-flex items-center gap-2 text-copper hover:text-copper-deep font-bold transition-colors duration-300 shrink-0">
        Tous les articles
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {BLOG_ARTICLES.slice(0, 3).map((article, idx) => (
        <a href={`/blog/${article.slug}`} class="group block bg-white rounded-2xl overflow-hidden border border-hairline hover:border-copper/30 hover:shadow-xl transition-all duration-500">
          <div class={`relative h-52 bg-gradient-to-br ${bgColors[idx]} flex items-center justify-center overflow-hidden`}>
            <!-- Category tag -->
            <span class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-ink text-xs font-bold px-3 py-1.5 rounded-full shadow-sm z-10">
              Conseil
            </span>
            <!-- Abstract illustration -->
            <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" class="text-copper/25 group-hover:scale-110 transition-transform duration-700" aria-hidden="true">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <div class="p-6">
            <time datetime={article.date} class="text-steel text-xs font-medium mb-3 block">
              {new Date(article.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
            </time>
            <h3 class="text-lg font-bold text-ink group-hover:text-copper transition-colors duration-300 leading-snug mb-3">
              {article.title}
            </h3>
            <p class="text-steel text-sm leading-relaxed line-clamp-2">{article.excerpt}</p>
            <span class="inline-flex items-center gap-1.5 text-copper font-bold text-sm mt-4 group-hover:gap-2.5 transition-all duration-300">
              Lire l'article
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
