<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[60] bg-ink text-white p-4 md:p-5 transform translate-y-0 transition-transform duration-500"
>
  <div class="container-site flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-body-sm text-steel-light max-w-xl">
      Nous utilisons des cookies essentiels au fonctionnement du site. En
      continuant, vous acceptez leur utilisation.
    </p>
    <div class="flex items-center gap-3 shrink-0">
      <a
        href="/politique-confidentialite"
        class="text-sm text-steel-light hover:text-white transition-colors duration-300 underline underline-offset-4"
      >
        En savoir plus
      </a>
      <button
        id="accept-cookies"
        class="bg-copper text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-copper-deep transition-all duration-300"
      >
        Accepter
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById("cookie-banner");
  const acceptBtn = document.getElementById("accept-cookies");

  if (!localStorage.getItem("cookies-accepted")) {
    banner?.classList.remove("hidden");
  } else {
    banner?.classList.add("hidden");
  }

  acceptBtn?.addEventListener("click", () => {
    localStorage.setItem("cookies-accepted", "true");
    banner?.classList.add("translate-y-full", "opacity-0");
    setTimeout(() => banner?.remove(), 500);
  });
</script>
