---
import { TESTIMONIALS } from "../data/company";

const platformIcons: Record<string, string> = {
  Google: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-4-4 1.41-1.41L11 14.17l6.59-6.59L19 9l-8 8z",
  Trustpilot: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
  Facebook: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
};

const avatarColors = ["#C7764A", "#8B7355", "#A05A35", "#6B3A20"];
const avatarBgs = ["#FDE8D5", "#E8E2D8", "#F5E0D0", "#E5D5C8"];
---

<section class="py-24 md:py-28 bg-canvas overflow-hidden">
  <div class="container-site">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <span class="inline-block text-copper font-bold uppercase tracking-[0.25em] text-xs bg-copper/5 px-4 py-2 rounded-full mb-6">
        Ils nous font confiance
      </span>
      <h2 class="text-display text-ink mb-5">
        La parole<br class="md:hidden" />
        <span class="text-copper">à nos clients</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
      {TESTIMONIALS.map((t, idx) => (
        <div class="group bg-surface rounded-2xl p-6 md:p-8 border border-hairline hover:border-copper/20 hover:shadow-xl transition-all duration-500 relative overflow-hidden">
          {/* Quote mark */}
          <div class="absolute top-4 right-6 text-7xl font-serif text-copper/8 leading-none pointer-events-none select-none" aria-hidden="true">
            &ldquo;
          </div>

          {/* Platform badge */}
          <div class="flex items-center gap-2 mb-5 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class={t.source === "Google" ? "text-green-600" : t.source === "Trustpilot" ? "text-green-700" : "text-blue-600"} aria-hidden="true">
              <path d={platformIcons[t.source] || platformIcons.Google}/>
            </svg>
            <span class="text-xs font-semibold text-steel uppercase tracking-wide">Avis {t.source}</span>
          </div>

          {/* Stars */}
          <div class="flex gap-0.5 mb-4 relative z-10">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          {/* Quote */}
          <blockquote class="text-ink text-body leading-relaxed mb-6 relative z-10 italic">
            &ldquo;{t.text}&rdquo;
          </blockquote>

          {/* Author */}
          <div class="flex items-center gap-3 relative z-10">
            <div class="w-11 h-11 rounded-full flex items-center justify-center font-bold text-sm shadow-sm" style={`background-color:${avatarBgs[idx]};color:${avatarColors[idx]}`}>
              {t.name.split(" ").map(n => n[0]).join("").slice(0, 2)}
            </div>
            <div>
              <p class="text-ink font-bold text-sm">{t.name}</p>
              <p class="text-steel text-xs">Client vérifié</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Summary stat -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-6 bg-surface rounded-2xl px-8 py-5 border border-hairline">
        <div class="text-center">
          <p class="text-3xl font-extrabold text-ink">4,9</p>
          <div class="flex gap-0.5 justify-center my-1">
            {[...Array(5)].map(() => (<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>))}
          </div>
          <p class="text-steel text-xs">Note moyenne</p>
        </div>
        <div class="w-px h-12 bg-hairline" aria-hidden="true"></div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-ink">350+</p>
          <p class="text-steel text-xs mt-1">Avis vérifiés</p>
        </div>
      </div>
    </div>
  </div>
</section>
