---
import { COMPANY } from "../data/company";

const advantages = [
  {
    title: "Disponibilité 24h/24",
    desc: "Nous répondons à votre appel en moins de 3 sonneries, de jour comme de nuit, week-ends et jours fériés inclus.",
    icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z",
    image: "https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=400&q=80&fit=crop",
  },
  {
    title: "Diagnostic de précision",
    desc: "Caméra thermique, détection acoustique, gaz traceur : nous localisons le problème au millimètre près, sans destruction.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
    image: "https://images.unsplash.com/photo-1581092335871-4c7b80f0bdd3?w=400&q=80&fit=crop",
  },
  {
    title: `Intervention en ${COMPANY.delay}`,
    desc: "Équipés du meilleur matériel, nous résolvons 95% des problèmes en une seule visite. Propre, rapide, efficace.",
    icon: "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z",
    image: "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=400&q=80&fit=crop",
  },
];
---

<section class="relative py-24 md:py-28 bg-canvas overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.025] pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="grid-adv" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="0.8" fill="currentColor"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-adv)"/>
    </svg>
  </div>

  <div class="container-site relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {advantages.map((adv, i) => (
        <div class="group relative bg-surface rounded-[1.75rem] overflow-hidden border border-hairline hover:border-copper/30 hover:shadow-2xl hover:shadow-copper/5 transition-all duration-700">
          <!-- Top image -->
          <div class="relative h-36 overflow-hidden">
            <img
              src={adv.image}
              alt=""
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <!-- Icon floating over -->
            <div class="absolute bottom-0 left-5 translate-y-1/2 w-12 h-12 rounded-2xl bg-copper text-white flex items-center justify-center shadow-xl shadow-copper/30 group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={adv.icon}/>
              </svg>
            </div>
          </div>
          <!-- Content -->
          <div class="p-6 pt-8 pb-7">
            <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-copper transition-colors duration-300">{adv.title}</h3>
            <p class="text-steel text-sm leading-relaxed">{adv.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
